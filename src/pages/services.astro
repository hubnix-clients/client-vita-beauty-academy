---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
---
<Layout title="Services">
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: var(--color-secondary)">What we offer</p>
      <h1 class="text-5xl font-bold text-white mb-4">Our services</h1>
      <p class="text-[var(--color-muted)] text-lg max-w-xl mb-16">{site.description}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {site.services.map((s: {name: string; description?: string}) => (
          <div class="p-8 rounded-2xl border border-white/[0.06] bg-[var(--color-surface)]">
            <h2 class="text-white font-semibold text-xl mb-3">{s.name}</h2>
            {s.description && <p class="text-[var(--color-muted)] leading-relaxed">{s.description}</p>}
          </div>
        ))}
      </div>

      <div class="mt-16 p-8 rounded-2xl text-center" style="background: var(--color-primary)20; border: 1px solid var(--color-primary)30">
        <h3 class="text-white font-bold text-2xl mb-3">Have a question about our services?</h3>
        <a href="/contact"
          class="inline-flex px-8 py-3 rounded-xl text-white font-semibold transition-opacity hover:opacity-90"
          style="background: var(--color-primary)">
          Get in touch
        </a>
      </div>
    </div>
  </section>
</Layout>
