---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
const lang = site.language || 'en';
const t: Record<string, Record<string, string>> = {
  en: { label: 'What we offer', title: 'Our services', cta_title: 'Have a question about our services?', cta_btn: 'Get in touch' },
  it: { label: 'Cosa offriamo', title: 'I nostri servizi', cta_title: 'Hai una domanda sui nostri servizi?', cta_btn: 'Contattaci' },
  uk: { label: 'Що ми пропонуємо', title: 'Наші послуги', cta_title: 'Маєте питання про наші послуги?', cta_btn: 'Зв\'язатися' },
};
const s = t[lang] ?? t['en'];
---
<Layout title={s.title}>
  <section style="padding:80px 0;">
    <div style="max-width:1200px; margin:0 auto; padding:0 24px;">
      <p style="font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--color-secondary); margin:0 0 16px;">{s.label}</p>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem); font-weight:700; color:var(--color-text); margin:0 0 16px;">{s.title}</h1>
      <p style="color:var(--color-muted); font-size:1.1rem; max-width:560px; margin:0 0 56px; line-height:1.7;">{site.description}</p>

      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:24px;">
        {site.services.map((sv: {name:string; description?:string}) => (
          <div style="padding:32px; border-radius:18px; border:1px solid var(--color-border); background:var(--color-surface);">
            <div style="width:36px; height:36px; border-radius:10px; background:color-mix(in srgb, var(--color-primary) 12%, transparent); margin-bottom:20px; display:flex; align-items:center; justify-content:center;">
              <div style="width:8px; height:8px; border-radius:50%; background:var(--color-secondary);"></div>
            </div>
            <h2 style="font-size:1.1rem; font-weight:600; color:var(--color-text); margin:0 0 12px;">{sv.name}</h2>
            {sv.description && <p style="color:var(--color-muted); font-size:14px; line-height:1.6; margin:0;">{sv.description}</p>}
          </div>
        ))}
      </div>

      <div style="margin-top:64px; padding:40px; border-radius:20px; text-align:center; background:color-mix(in srgb, var(--color-primary) 8%, transparent); border:1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);">
        <h3 style="font-size:1.5rem; font-weight:700; color:var(--color-text); margin:0 0 20px;">{s.cta_title}</h3>
        <a href="/contact" class="btn-primary">{s.cta_btn}</a>
      </div>
    </div>
  </section>
</Layout>
