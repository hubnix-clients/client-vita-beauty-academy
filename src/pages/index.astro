---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
---
<Layout>
  <!-- Hero -->
  <section class="min-h-[90vh] flex items-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full blur-3xl" style="background: var(--color-primary)"></div>
      <div class="absolute bottom-1/4 right-1/4 w-72 h-72 rounded-full blur-3xl" style="background: var(--color-secondary)"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 py-24 relative z-10">
      <h1 class="text-5xl lg:text-7xl font-extrabold text-white leading-tight mb-6 tracking-tight">
        {site.tagline || site.business_name}
      </h1>
      <p class="text-xl text-[var(--color-muted)] max-w-xl mb-10 leading-relaxed">{site.description}</p>
      <div class="flex flex-wrap gap-4">
        <a href="/contact"
          class="px-8 py-4 rounded-2xl font-semibold text-white text-base transition-opacity hover:opacity-90"
          style="background: var(--color-primary)">
          Get in touch
        </a>
        <a href="/services"
          class="px-8 py-4 rounded-2xl font-semibold text-white text-base border border-white/20 hover:bg-white/5 transition-colors">
          Our services
        </a>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  {site.services && site.services.length > 0 && (
    <section class="py-24 bg-[var(--color-surface)]">
      <div class="max-w-6xl mx-auto px-6">
        <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: var(--color-secondary)">What we do</p>
        <h2 class="text-4xl font-bold text-white mb-12">Our services</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {site.services.map((s: {name: string; description?: string}) => (
            <div class="p-6 rounded-2xl border border-white/[0.06] bg-[var(--color-bg)] hover:border-white/20 transition-colors">
              <div class="w-10 h-10 rounded-xl mb-4 flex items-center justify-center" style="background: var(--color-primary)20">
                <div class="w-2 h-2 rounded-full" style="background: var(--color-secondary)"></div>
              </div>
              <h3 class="text-white font-semibold text-lg mb-2">{s.name}</h3>
              {s.description && <p class="text-[var(--color-muted)] text-sm leading-relaxed">{s.description}</p>}
            </div>
          ))}
        </div>
        <div class="mt-10">
          <a href="/services" class="text-sm font-semibold hover:underline" style="color: var(--color-secondary)">View all services →</a>
        </div>
      </div>
    </section>
  )}

  <!-- Contact CTA -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-bold text-white mb-4">Ready to get started?</h2>
      <p class="text-[var(--color-muted)] mb-8 max-w-lg mx-auto">Reach out today and let's talk about how we can help your business.</p>
      <a href="/contact"
        class="inline-flex px-10 py-4 rounded-2xl font-semibold text-white text-base transition-opacity hover:opacity-90"
        style="background: var(--color-primary)">
        Contact us
      </a>
    </div>
  </section>
</Layout>
