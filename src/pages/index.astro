---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
const lang = site.language || 'en';
const t: Record<string, Record<string, string>> = {
  en: { what_we_do: 'What we do', our_services: 'Our services', view_all: 'View all services →', cta_title: 'Ready to get started?', cta_sub: 'Reach out today and let\'s talk about how we can help your business.', contact_us: 'Contact us', cta: 'Get in touch', services_btn: 'Our services' },
  it: { what_we_do: 'Cosa facciamo', our_services: 'I nostri servizi', view_all: 'Vedi tutti i servizi →', cta_title: 'Pronta a iniziare?', cta_sub: 'Contattaci oggi e parliamo di come possiamo aiutare la tua attività.', contact_us: 'Contattaci', cta: 'Contattaci', services_btn: 'I nostri servizi' },
  uk: { what_we_do: 'Що ми робимо', our_services: 'Наші послуги', view_all: 'Всі послуги →', cta_title: 'Готові розпочати?', cta_sub: 'Зв\'яжіться з нами сьогодні.', contact_us: 'Зв\'язатися', cta: 'Зв\'язатися', services_btn: 'Наші послуги' },
};
const s = t[lang] ?? t['en'];
---
<Layout>
  <!-- Hero -->
  <section style="min-height:90vh; display:flex; align-items:center; position:relative; overflow:hidden;">
    <div style="position:absolute; inset:0; opacity:0.15; pointer-events:none;">
      <div style="position:absolute; top:25%; left:20%; width:400px; height:400px; border-radius:50%; filter:blur(80px); background:var(--color-primary);"></div>
      <div style="position:absolute; bottom:20%; right:20%; width:300px; height:300px; border-radius:50%; filter:blur(80px); background:var(--color-secondary);"></div>
    </div>
    <div style="max-width:1200px; margin:0 auto; padding:80px 24px; position:relative; z-index:1;">
      <h1 style="font-size:clamp(2.5rem,6vw,4.5rem); font-weight:800; color:var(--color-text); line-height:1.1; margin:0 0 24px; letter-spacing:-0.02em;">
        {site.tagline || site.business_name}
      </h1>
      <p style="font-size:1.2rem; color:var(--color-muted); max-width:560px; margin:0 0 40px; line-height:1.7;">{site.description}</p>
      <div style="display:flex; flex-wrap:wrap; gap:16px;">
        <a href="/contact" class="btn-primary">{s.cta}</a>
        <a href="/services" class="btn-outline">{s.services_btn}</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  {site.services && site.services.length > 0 && (
    <section style="padding:80px 0; background:var(--color-surface);">
      <div style="max-width:1200px; margin:0 auto; padding:0 24px;">
        <p style="font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--color-secondary); margin:0 0 16px;">{s.what_we_do}</p>
        <h2 style="font-size:2.5rem; font-weight:700; color:var(--color-text); margin:0 0 48px;">{s.our_services}</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:24px;">
          {site.services.map((sv: {name:string; description?:string}) => (
            <div style="padding:28px; border-radius:18px; border:1px solid var(--color-border); background:var(--color-bg);">
              <div style="width:36px; height:36px; border-radius:10px; background:color-mix(in srgb, var(--color-primary) 12%, transparent); margin-bottom:16px; display:flex; align-items:center; justify-content:center;">
                <div style="width:8px; height:8px; border-radius:50%; background:var(--color-secondary);"></div>
              </div>
              <h3 style="font-size:1.1rem; font-weight:600; color:var(--color-text); margin:0 0 10px;">{sv.name}</h3>
              {sv.description && <p style="color:var(--color-muted); font-size:14px; line-height:1.6; margin:0;">{sv.description}</p>}
            </div>
          ))}
        </div>
        <div style="margin-top:36px;">
          <a href="/services" style="color:var(--color-secondary); font-weight:600; font-size:14px;">{s.view_all}</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section style="padding:80px 0; text-align:center;">
    <div style="max-width:1200px; margin:0 auto; padding:0 24px;">
      <h2 style="font-size:2.5rem; font-weight:700; color:var(--color-text); margin:0 0 16px;">{s.cta_title}</h2>
      <p style="color:var(--color-muted); margin:0 0 32px; max-width:480px; margin-left:auto; margin-right:auto;">{s.cta_sub}</p>
      <a href="/contact" class="btn-primary">{s.contact_us}</a>
    </div>
  </section>
</Layout>
