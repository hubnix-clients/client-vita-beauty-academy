---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
const lang = site.language || 'en';
const t: Record<string, Record<string, string>> = {
  en: { label: 'Who we are', contact_btn: 'Contact us' },
  it: { label: 'Chi siamo', contact_btn: 'Contattaci' },
  uk: { label: 'Хто ми', contact_btn: 'Зв\'язатися' },
};
const s = t[lang] ?? t['en'];
---
<Layout title={s.label}>
  <section style="padding:80px 0;">
    <div style="max-width:860px; margin:0 auto; padding:0 24px;">
      <p style="font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--color-secondary); margin:0 0 16px;">{s.label}</p>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem); font-weight:700; color:var(--color-text); margin:0 0 32px;">{site.business_name}</h1>
      <p style="font-size:1.2rem; color:var(--color-muted); line-height:1.8; margin:0 0 40px;">{site.description}</p>

      {site.contact.address && (
        <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:20px;">
          <div style="width:36px; height:36px; min-width:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; background:color-mix(in srgb, var(--color-primary) 12%, transparent);">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style={`color:var(--color-secondary)`}>
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <p style="color:var(--color-muted); margin:0; line-height:1.6;">{site.contact.address}</p>
        </div>
      )}

      <div style="margin-top:48px;">
        <a href="/contact" class="btn-primary">{s.contact_btn}</a>
      </div>
    </div>
  </section>
</Layout>
