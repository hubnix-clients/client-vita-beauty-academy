---
import site from '../content/site.json';
interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ${site.business_name}` : site.business_name;
const pageDesc = description || site.description;
---
<!DOCTYPE html>
<html lang={site.language}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDesc} />
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --color-primary:   #1E88E5;
      --color-secondary: #29B6F6;
      --color-bg:        #0a0f1a;
      --color-surface:   #111827;
      --color-text:      #e2e8f0;
      --color-muted:     #64748b;
    }
    body { font-family: 'Inter', system-ui, sans-serif; background: var(--color-bg); color: var(--color-text); }
    a { color: inherit; }
    ::selection { background: var(--color-primary); color: white; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Nav -->
  <header class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/80 backdrop-blur-xl border-b border-white/[0.06]">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-bold text-lg text-white">{site.business_name}</a>
      <nav class="hidden md:flex gap-1">
        <a href="/" class="px-4 py-2 text-sm text-[var(--color-muted)] hover:text-white rounded-lg hover:bg-white/5 transition-colors">Home</a>
        <a href="/services" class="px-4 py-2 text-sm text-[var(--color-muted)] hover:text-white rounded-lg hover:bg-white/5 transition-colors">Services</a>
        <a href="/about" class="px-4 py-2 text-sm text-[var(--color-muted)] hover:text-white rounded-lg hover:bg-white/5 transition-colors">About</a>
        <a href="/contact" class="px-4 py-2 text-sm text-[var(--color-muted)] hover:text-white rounded-lg hover:bg-white/5 transition-colors">Contact</a>
      </nav>
      {site.contact.phone && (
        <a href={`tel:${site.contact.phone}`}
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-[var(--color-primary)] hover:opacity-90 text-white text-sm font-medium transition-opacity">
          {site.contact.phone}
        </a>
      )}
    </div>
  </header>

  <main class="flex-1 pt-16">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/[0.06] mt-16">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <p class="font-bold text-white text-lg mb-2">{site.business_name}</p>
          {site.tagline && <p class="text-[var(--color-muted)] text-sm">{site.tagline}</p>}
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-muted)] mb-3">Contact</p>
          {site.contact.email && <p class="text-sm text-[var(--color-text)] mb-1"><a href={`mailto:${site.contact.email}`} class="hover:text-[var(--color-secondary)]">{site.contact.email}</a></p>}
          {site.contact.phone && <p class="text-sm text-[var(--color-text)] mb-1">{site.contact.phone}</p>}
          {site.contact.address && <p class="text-sm text-[var(--color-muted)]">{site.contact.address}</p>}
          {site.contact.hours && <p class="text-sm text-[var(--color-muted)]">{site.contact.hours}</p>}
        </div>
        <div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-muted)] mb-3">Follow</p>
          <div class="flex gap-3">
            {site.social.instagram && <a href={site.social.instagram} class="text-[var(--color-muted)] hover:text-white text-sm transition-colors">Instagram</a>}
            {site.social.facebook && <a href={site.social.facebook} class="text-[var(--color-muted)] hover:text-white text-sm transition-colors">Facebook</a>}
            {site.social.tiktok && <a href={site.social.tiktok} class="text-[var(--color-muted)] hover:text-white text-sm transition-colors">TikTok</a>}
          </div>
          {site.social.whatsapp && (
            <a href={`https://wa.me/${site.social.whatsapp.replace(/\D/g,'')}`}
              class="inline-flex items-center gap-2 mt-4 px-4 py-2 rounded-xl bg-[#25D366]/10 border border-[#25D366]/30 text-[#25D366] text-sm hover:bg-[#25D366]/20 transition-colors">
              WhatsApp
            </a>
          )}
        </div>
      </div>
      <div class="border-t border-white/[0.04] mt-8 pt-6 flex flex-col sm:flex-row justify-between items-center gap-2">
        <p class="text-[var(--color-muted)] text-xs">© {new Date().getFullYear()} {site.business_name}. All rights reserved.</p>
        <a href="/legal" class="text-[var(--color-muted)] text-xs hover:text-white transition-colors">Legal</a>
      </div>
    </div>
  </footer>
</body>
</html>
